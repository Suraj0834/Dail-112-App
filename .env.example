# ==============================================================================
# .env.example - Environment Variables Configuration
# ==============================================================================

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=dial112secure
MONGODB_URI=mongodb://admin:dial112secure@mongodb:27017/dial112?authSource=admin

# ── Node.js Backend ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
BASE_URL=http://localhost:5000
ALLOWED_ORIGIN=*
LOG_LEVEL=info

# ── Security & Authentication ─────────────────────────────────────────────────
JWT_SECRET=dial112-jwt-super-secret-key-change-in-prod
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# ── Python AI Service ─────────────────────────────────────────────────────────
AI_SERVICE_URL=http://ai-service:8000
AI_SERVICE_API_KEY=dial112-ai-secret
PYTHON_WORKERS=1

# ── Web Portal (React Vite) ───────────────────────────────────────────────────
VITE_API_URL=http://localhost:5000
VITE_SOCKET_URL=http://localhost:5000
VITE_GOOGLE_MAPS_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

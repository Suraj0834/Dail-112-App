<?xml version="1.0" encoding="utf-8"?>
<!-- Bottom-sheet style auth card: solid dark navy with rounded top corners and subtle top border -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Subtle top-edge glow/border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#25FFFFFF" />
            <corners
                android:topLeftRadius="32dp"
                android:topRightRadius="32dp" />
        </shape>
    </item>

    <!-- Main card body (1dp inset on all sides so top border shows through) -->
    <item
        android:top="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#121829" />
            <corners
                android:topLeftRadius="32dp"
                android:topRightRadius="32dp" />
        </shape>
    </item>

</layer-list>

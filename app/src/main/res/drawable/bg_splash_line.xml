<?xml version="1.0" encoding="utf-8"?>
<!-- Horizontal gradient divider line: transparent → blue → purple → transparent -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="0"
        android:startColor="#002979FF"
        android:centerColor="#7C4DFF"
        android:endColor="#002979FF" />
    <corners android:radius="1dp" />
</shape>

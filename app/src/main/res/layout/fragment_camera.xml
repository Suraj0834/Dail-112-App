<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_camera.xml - Camera Screen for Face Recognition / Weapon Detection / ANPR
    Design: Full-screen CameraX preview with capture button, mode label, result overlay
    Key elements: PreviewView, capture button, back button, mode label, result card, progress
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- ============================================================
         FULL SCREEN CAMERA PREVIEW
         ============================================================ -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ============================================================
         TOP OVERLAY - Back button & mode label
         ============================================================ -->

    <!-- Back button - top left -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="48dp"
        app:cardBackgroundColor="#80000000"
        app:cardCornerRadius="22dp"
        app:cardElevation="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:src="@drawable/ic_back"
            app:tint="@color/white" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Mode label - top center (e.g., "Face Recognition", "Weapon Detection", "ANPR") -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        app:cardBackgroundColor="#80000000"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_semibold"
            android:paddingHorizontal="20dp"
            android:paddingVertical="8dp"
            android:textColor="@color/white"
            android:textSize="14sp"
            tools:text="Face Recognition" />

    </com.google.android.material.card.MaterialCardView>

    <!-- ============================================================
         PROGRESS BAR - Shown during AI processing
         ============================================================ -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:indeterminateTint="@color/accent_blue"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible" />

    <!-- ============================================================
         CAPTURE BUTTON - Centered bottom
         ============================================================ -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnCapture"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="48dp"
        android:contentDescription="Capture"
        android:src="@drawable/ic_camera"
        app:backgroundTint="@color/white"
        app:fabCustomSize="72dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:maxImageSize="32dp"
        app:tint="@color/background_dark" />

    <!-- ============================================================
         RESULT OVERLAY CARD - Shown at bottom when result is available
         ============================================================ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardResult"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="140dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/background_card"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:strokeColor="@color/accent_blue"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Result label (e.g., "Match Found", "Weapon Detected", "Plate Recognized") -->
            <TextView
                android:id="@+id/tvResultLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/accent_green"
                android:textSize="16sp"
                tools:text="Match Found" />

            <!-- Result detail text -->
            <TextView
                android:id="@+id/tvResultDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                tools:text="Name: John Doe\nConfidence: 97.3%\nStatus: Wanted" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>

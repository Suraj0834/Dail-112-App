<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_police_home.xml - Police Officer Dashboard
    Design: Dark theme with greeting header, quick action grid cards, SOS alerts section
    Key elements: Greeting, badge, 6 quick action cards, active SOS alerts
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="100dp">

            <!-- ============================================================
                 HEADER SECTION - Officer greeting & badge
                 ============================================================ -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/headerSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gradient_dark"
                android:paddingHorizontal="20dp"
                android:paddingTop="56dp"
                android:paddingBottom="24dp"
                app:layout_constraintTop_toTopOf="parent">

                <!-- Officer greeting -->
                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    app:layout_constraintEnd_toStartOf="@id/ivProfilePic"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="Hello, Inspector! 👋" />

                <!-- Badge number -->
                <TextView
                    android:id="@+id/tvBadge"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:drawablePadding="6dp"
                    android:fontFamily="@font/poppins_regular"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    app:drawableStartCompat="@drawable/ic_badge"
                    app:drawableTint="@color/accent_blue"
                    app:layout_constraintEnd_toStartOf="@id/ivProfilePic"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvGreeting"
                    tools:text="Badge #4521" />

                <!-- Profile picture -->
                <ImageView
                    android:id="@+id/ivProfilePic"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_circle_accent"
                    android:contentDescription="Profile"
                    android:padding="8dp"
                    android:src="@drawable/ic_person_placeholder"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/white" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ============================================================
                 QUICK ACTIONS SECTION - 6 action cards in a 2-column grid
                 ============================================================ -->
            <TextView
                android:id="@+id/tvQuickActionsLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/poppins_bold"
                android:text="Quick Actions"
                android:textColor="@color/white"
                android:textSize="18sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/headerSection" />

            <!-- Grid of action cards using nested ConstraintLayout -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/gridActions"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvQuickActionsLabel">

                <!-- ROW 1: Face Recognition | Weapon Detection -->

                <!-- Card: Face Recognition -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFaceRecognition"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    app:cardBackgroundColor="@color/background_card"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp"
                    app:layout_constraintEnd_toStartOf="@id/cardWeaponDetection"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@color/card_bg_blue"
                            android:contentDescription="Face Recognition"
                            android:padding="8dp"
                            android:src="@drawable/ic_face_scan"
                            app:tint="@color/accent_blue" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/poppins_semibold"
                            android:gravity="center"
                            android:text="Face\nRecognition"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Card: Weapon Detection -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardWeaponDetection"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    app:cardBackgroundColor="@color/background_card"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toEndOf="@id/cardFaceRecognition"
                    app:layout_constraintTop_toTopOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@color/card_bg_red"
                            android:contentDescription="Weapon Detection"
                            android:padding="8dp"
                            android:src="@drawable/ic_weapon"
                            app:tint="@color/primary_red" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/poppins_semibold"
                            android:gravity="center"
                            android:text="Weapon\nDetection"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ROW 2: ANPR Scan | Case Management -->

                <!-- Card: ANPR Scan -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAnpr"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="4dp"
                    app:cardBackgroundColor="@color/background_card"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp"
                    app:layout_constraintEnd_toStartOf="@id/cardCaseManagement"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cardFaceRecognition">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@color/card_bg_teal"
                            android:contentDescription="ANPR Scan"
                            android:padding="8dp"
                            android:src="@drawable/ic_anpr"
                            app:tint="@color/accent_teal" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/poppins_semibold"
                            android:gravity="center"
                            android:text="ANPR\nScan"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Card: Case Management -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCaseManagement"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="@color/background_card"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toEndOf="@id/cardAnpr"
                    app:layout_constraintTop_toBottomOf="@id/cardWeaponDetection">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@color/card_bg_orange"
                            android:contentDescription="Case Management"
                            android:padding="8dp"
                            android:src="@drawable/ic_document"
                            app:tint="@color/accent_orange" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/poppins_semibold"
                            android:gravity="center"
                            android:text="Case\nManagement"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ROW 3: Crime Map | Vehicle Lookup -->

                <!-- Card: Crime Map -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCrimeMap"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="4dp"
                    app:cardBackgroundColor="@color/background_card"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp"
                    app:layout_constraintEnd_toStartOf="@id/cardVehicle"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cardAnpr">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@color/card_bg_green"
                            android:contentDescription="Crime Map"
                            android:padding="8dp"
                            android:src="@drawable/ic_map_pin"
                            app:tint="@color/accent_green" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/poppins_semibold"
                            android:gravity="center"
                            android:text="Crime\nMap"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Card: Vehicle Lookup -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardVehicle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="@color/background_card"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toEndOf="@id/cardCrimeMap"
                    app:layout_constraintTop_toBottomOf="@id/cardCaseManagement">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@color/card_bg_purple"
                            android:contentDescription="Vehicle Lookup"
                            android:padding="8dp"
                            android:src="@drawable/ic_car"
                            app:tint="@color/accent_purple" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/poppins_semibold"
                            android:gravity="center"
                            android:text="Vehicle\nLookup"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ============================================================
                 PCR VAN CARD (full-width) below the 3×2 grid
                 ============================================================ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPcrVan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/background_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/accent_blue"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/gridActions">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@color/card_bg_blue"
                        android:contentDescription="PCR Vans"
                        android:padding="10dp"
                        android:src="@drawable/ic_car"
                        app:tint="@color/accent_blue" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_bold"
                            android:text="PCR Van Fleet"
                            android:textColor="@color/white"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_regular"
                            android:text="View all vans &amp; update your status"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Go"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/accent_blue" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ============================================================                 CRIMINAL DATABASE CARD (full-width) below PCR Van
                 ============================================================ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCriminalSearch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/background_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/primary_red"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardPcrVan">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@color/card_bg_red"
                        android:contentDescription="Criminal Database"
                        android:padding="10dp"
                        android:src="@drawable/ic_search"
                        app:tint="@color/primary_red" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_bold"
                            android:text="Criminal Database"
                            android:textColor="@color/white"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_regular"
                            android:text="Search criminal records &amp; history"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Go"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/primary_red" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ============================================================                 ACTIVE SOS ALERTS SECTION
                 ============================================================ -->
            <TextView
                android:id="@+id/tvSosAlertsLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="28dp"
                android:fontFamily="@font/poppins_bold"
                android:text="Active SOS Alerts"
                android:textColor="@color/sos_red"
                android:textSize="18sp"
                app:layout_constraintEnd_toStartOf="@id/tvViewAllSos"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardCriminalSearch" />

            <TextView
                android:id="@+id/tvViewAllSos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="View All →"
                android:textColor="@color/accent_blue"
                android:textSize="13sp"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintBaseline_toBaselineOf="@id/tvSosAlertsLabel"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- RecyclerView for SOS alerts -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSosAlerts"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvSosAlertsLabel" />

            <!-- Empty state for SOS alerts -->
            <TextView
                android:id="@+id/tvNoAlerts"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center"
                android:text="No active SOS alerts"
                android:textColor="@color/text_hint"
                android:textSize="14sp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvSosAlertsLabel"
                tools:visibility="visible" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

<?xml version="1.0" encoding="utf-8"?>
<!--
    item_pcr_van.xml - Single PCR van card in the RecyclerView
    Shows: plate number, van name, status badge, assigned officer, last location
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/background_card"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top row: van name + status chip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Van icon -->
            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@color/card_bg_blue"
                android:contentDescription="PCR Van"
                android:padding="6dp"
                android:src="@drawable/ic_car"
                app:tint="@color/accent_blue" />

            <!-- Name + plate -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvVanName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    tools:text="PCR-01 Delhi" />

                <TextView
                    android:id="@+id/tvPlateNo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_regular"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    tools:text="DL 1P 0001" />

            </LinearLayout>

            <!-- Status chip -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chipStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/white"
                android:textSize="11sp"
                app:chipCornerRadius="8dp"
                app:chipMinHeight="28dp"
                tools:chipBackgroundColor="@color/accent_green"
                tools:text="Available" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="@color/divider" />

        <!-- Officer info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_person_placeholder"
                app:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/tvOfficerName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                tools:text="Insp. Rajesh Kumar • Badge #4521" />

        </LinearLayout>

        <!-- Location -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_map_pin"
                app:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                tools:text="Connaught Place, Delhi" />

            <TextView
                android:id="@+id/tvLastSeen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                tools:text="2 min ago" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_forgot_password.xml  |  Dial-112 Forgot Password Screen
    ─────────────────────────────────────────────────────────────────
    Design  : Two-state layout controlled by Kotlin/Java visibility:
              • State 1 (groupEmailEntry, visible by default) —
                Enter email → tap "Send OTP" → OTP email dispatched.
              • State 2 (groupOtpEntry, gone by default) —
                Enter 6-digit OTP sent to email, set new password,
                tap "Reset Password".
    Requires: bg_auth_card, bg_splash_glow, bg_otp_box drawables;
              ic_email, ic_lock icons; poppins font family.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_dark">

    <!-- ── Ambient glow ─────────────────────────────────────────────────── -->
    <View
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_marginEnd="-80dp"
        android:layout_marginTop="60dp"
        android:alpha="0.35"
        android:background="@drawable/bg_splash_glow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ── Back button ──────────────────────────────────────────────────── -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Back"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white" />

    <!-- ── Lock/Email illustration ───────────────────────────────────────── -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieIllustration"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_marginTop="48dp"
        app:lottie_rawRes="@raw/anim_shield"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ════════════════════════════════════════════════════════════════════
         STATE 1 — Email Entry  (groupEmailEntry)
         Visible on first load. Replaced by groupOtpEntry after OTP is sent.
         ════════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/groupEmailEntry"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:orientation="vertical"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lottieIllustration">

        <!-- Card surface -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_auth_card"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="36dp"
            android:paddingBottom="48dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:text="Forgot Password?"
                android:textColor="@color/white"
                android:textSize="26sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/poppins_regular"
                android:lineSpacingMultiplier="1.4"
                android:text="Enter your registered email address. We\'ll send you a 6-digit OTP to reset your password."
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <!-- Email field -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:hint="Email Address"
                app:boxBackgroundColor="#0D1221"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:boxStrokeColor="@color/accent_blue"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="@color/text_secondary"
                app:startIconDrawable="@drawable/ic_email"
                app:startIconTint="@color/accent_blue">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/white"
                    android:textColorHint="@color/text_hint" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Send OTP button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendOtp"
                style="@style/Widget.Dial112.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/poppins_semibold"
                android:letterSpacing="0.08"
                android:text="SEND OTP"
                android:textSize="14sp" />

            <!-- Loading indicator -->
            <ProgressBar
                android:id="@+id/progressBarEmail"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:layout_marginTop="12dp"
                android:indeterminate="true"
                android:visibility="gone" />

            <!-- Back to login -->
            <TextView
                android:id="@+id/tvBackToLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/poppins_regular"
                android:text="Back to Sign In"
                android:textColor="@color/accent_blue"
                android:textSize="13sp" />

        </LinearLayout>
    </LinearLayout>

    <!-- ════════════════════════════════════════════════════════════════════
         STATE 2 — OTP + New Password  (groupOtpEntry)
         Set to VISIBLE and groupEmailEntry to GONE after OTP is dispatched.
         ════════════════════════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/groupOtpEntry"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:fillViewport="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lottieIllustration">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_auth_card"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="36dp"
            android:paddingBottom="48dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:text="Check Your Email"
                android:textColor="@color/white"
                android:textSize="26sp" />

            <TextView
                android:id="@+id/tvOtpSentTo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/poppins_regular"
                android:lineSpacingMultiplier="1.4"
                android:text="Enter the 6-digit OTP sent to your email address."
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <!-- ── 6 OTP input boxes ───────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="Enter OTP"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- OTP digit 1 -->
                <EditText
                    android:id="@+id/etOtp1"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_otp_box"
                    android:gravity="center"
                    android:inputType="numberDecimal"
                    android:maxLength="1"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:fontFamily="@font/poppins_bold" />

                <!-- OTP digit 2 -->
                <EditText
                    android:id="@+id/etOtp2"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_otp_box"
                    android:gravity="center"
                    android:inputType="numberDecimal"
                    android:maxLength="1"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:fontFamily="@font/poppins_bold" />

                <!-- OTP digit 3 -->
                <EditText
                    android:id="@+id/etOtp3"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="12dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_otp_box"
                    android:gravity="center"
                    android:inputType="numberDecimal"
                    android:maxLength="1"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:fontFamily="@font/poppins_bold" />

                <!-- OTP digit 4 -->
                <EditText
                    android:id="@+id/etOtp4"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_otp_box"
                    android:gravity="center"
                    android:inputType="numberDecimal"
                    android:maxLength="1"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:fontFamily="@font/poppins_bold" />

                <!-- OTP digit 5 -->
                <EditText
                    android:id="@+id/etOtp5"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_otp_box"
                    android:gravity="center"
                    android:inputType="numberDecimal"
                    android:maxLength="1"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:fontFamily="@font/poppins_bold" />

                <!-- OTP digit 6 -->
                <EditText
                    android:id="@+id/etOtp6"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_otp_box"
                    android:gravity="center"
                    android:inputType="numberDecimal"
                    android:maxLength="1"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:fontFamily="@font/poppins_bold" />

            </LinearLayout>

            <!-- ── New Password ───────────────────────────────────────── -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:hint="New Password"
                app:boxBackgroundColor="#0D1221"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:boxStrokeColor="@color/accent_blue"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="@color/text_secondary"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="@color/text_secondary"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="@color/accent_blue">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNewPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="@color/white"
                    android:textColorHint="@color/text_hint" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── Confirm Password ───────────────────────────────────── -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="Confirm New Password"
                app:boxBackgroundColor="#0D1221"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:boxStrokeColor="@color/accent_blue"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="@color/text_secondary"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="@color/text_secondary"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="@color/accent_blue">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="@color/white"
                    android:textColorHint="@color/text_hint" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Reset Password button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResetPassword"
                style="@style/Widget.Dial112.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/poppins_semibold"
                android:letterSpacing="0.08"
                android:text="RESET PASSWORD"
                android:textSize="14sp" />

            <!-- Loading indicator -->
            <ProgressBar
                android:id="@+id/progressBarOtp"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:layout_marginTop="12dp"
                android:indeterminate="true"
                android:visibility="gone" />

            <!-- Resend OTP link + countdown -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_regular"
                    android:text="Didn\'t receive it? "
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvResendOtp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="Resend OTP"
                    android:textColor="@color/accent_blue"
                    android:textSize="13sp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

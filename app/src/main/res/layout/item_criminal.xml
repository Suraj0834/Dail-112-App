<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_rounded"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="10dp"
    android:foreground="?attr/selectableItemBackground"
    android:orientation="horizontal"
    android:padding="14dp">

    <!-- Photo / Initials -->
    <FrameLayout
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="14dp">

        <ImageView
            android:id="@+id/ivCriminalPhoto"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_circle_red"
            android:scaleType="centerCrop"
            android:visibility="gone"
            tools:src="@drawable/ic_person_placeholder" />

        <TextView
            android:id="@+id/tvCriminalInitials"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_circle_red"
            android:fontFamily="@font/poppins_bold"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="20sp"
            tools:text="RK" />

    </FrameLayout>

    <!-- Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvCriminalName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/white"
                android:textSize="15sp"
                tools:text="Rajesh Kumar" />

            <!-- Danger Level Chip -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chipDangerLevel"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/white"
                android:textSize="10sp"
                app:chipCornerRadius="6dp"
                app:chipMinTouchTargetSize="0dp"
                tools:text="HIGH" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvCriminalAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/poppins_regular"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#80FFFFFF"
            android:textSize="12sp"
            tools:text="Last seen: MG Road, Bangalore" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Warrant Status Badge -->
            <TextView
                android:id="@+id/tvWarrantStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_red"
                android:fontFamily="@font/poppins_semibold"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textColor="@color/white"
                android:textSize="10sp"
                tools:text="WARRANT ACTIVE" />

            <View
                android:id="@+id/dividerWarrant"
                android:layout_width="1dp"
                android:layout_height="12dp"
                android:layout_marginHorizontal="8dp"
                android:background="#40FFFFFF" />

            <TextView
                android:id="@+id/tvCrimesCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_regular"
                android:textColor="#80FFFFFF"
                android:textSize="11sp"
                tools:text="3 offenses" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>

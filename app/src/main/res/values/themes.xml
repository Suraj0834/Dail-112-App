<?xml version="1.0" encoding="utf-8"?>
<!--
    themes.xml - Dial-112 Material 3 Dark Theme
    Uses Poppins font and custom dark color scheme
-->
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ======================================================================
         MAIN APP THEME - Dark Material 3
         ====================================================================== -->
    <style name="Theme.Dial112" parent="Theme.Material3.Dark.NoActionBar">

        <!-- Material 3 Color System -->
        <item name="colorPrimary">@color/primary_red</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/primary_red_dark</item>
        <item name="colorOnPrimaryContainer">@color/white</item>

        <item name="colorSecondary">@color/accent_blue</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="colorError">@color/error_red</item>
        <item name="colorOnError">@color/white</item>

        <item name="colorSurface">@color/background_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <!-- Status bar transparent for edge-to-edge -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>

        <!-- Window settings -->
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:windowTranslucentStatus">false</item>

        <!-- Poppins as default font -->
        <item name="android:fontFamily">@font/poppins_regular</item>

        <!-- Ripple effect color -->
        <item name="colorControlHighlight">#20FFFFFF</item>

        <!-- Navigation Component (fragment) animations -->
        <item name="android:windowAnimationStyle">@style/FragmentTransitionAnimation</item>
    </style>

    <!-- ======================================================================
         SPLASH SCREEN THEME
         ====================================================================== -->
    <style name="Theme.Dial112.Splash" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:windowBackground">@drawable/bg_splash</item>
    </style>

    <!-- ======================================================================
         FRAGMENT TRANSITION ANIMATIONS
         ====================================================================== -->
    <style name="FragmentTransitionAnimation" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>

    <!-- ======================================================================
         BOTTOM NAVIGATION BAR STYLE
         ====================================================================== -->
    <style name="Widget.Dial112.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/background_card</item>
        <item name="itemIconTint">@color/bottom_nav_item_color</item>
        <item name="itemTextColor">@color/bottom_nav_item_color</item>
        <item name="itemRippleColor">@color/accent_red</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="elevation">16dp</item>
    </style>

    <!-- ======================================================================
         CARD STYLE
         ====================================================================== -->
    <style name="Widget.Dial112.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/background_card</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">8dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- ======================================================================
         BUTTON STYLES
         ====================================================================== -->
    <style name="Widget.Dial112.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary_red</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:fontFamily">@font/poppins_semibold</item>
    </style>

    <style name="Widget.Dial112.Button.SOS" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/sos_red</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">80dp</item>
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="elevation">16dp</item>
    </style>

    <!-- ======================================================================
         TEXT APPEARANCE STYLES
         ====================================================================== -->
    <style name="TextAppearance.Poppins.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/white</item>
    </style>

</resources>
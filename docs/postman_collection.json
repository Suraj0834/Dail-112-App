{
    "info": {
        "name": "Dial-112 Control Room API",
        "description": "API endpoints used by the Web Portal to fetch dashboard stats, manage cases, police officers, SOS alerts, and databases.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Authentication",
            "item": [
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"control_room@police.gov.in\",\n    \"password\": \"admin123\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{BASE_URL}}/api/auth/login",
                            "host": [
                                "{{BASE_URL}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "login"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Portal Dashboard",
            "item": [
                {
                    "name": "Get Stats",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{jwt_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{BASE_URL}}/api/portal/dashboard/stats",
                            "host": [
                                "{{BASE_URL}}"
                            ],
                            "path": [
                                "api",
                                "portal",
                                "dashboard",
                                "stats"
                            ]
                        }
                    }
                },
                {
                    "name": "Monthly Trends",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{jwt_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{BASE_URL}}/api/portal/dashboard/trends",
                            "host": [
                                "{{BASE_URL}}"
                            ],
                            "path": [
                                "api",
                                "portal",
                                "dashboard",
                                "trends"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Portal Cases",
            "item": [
                {
                    "name": "Get All Cases",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{jwt_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{BASE_URL}}/api/cases?limit=20&page=1",
                            "host": [
                                "{{BASE_URL}}"
                            ],
                            "path": [
                                "api",
                                "cases"
                            ],
                            "query": [
                                {
                                    "key": "limit",
                                    "value": "20"
                                },
                                {
                                    "key": "page",
                                    "value": "1"
                                }
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Portal Police",
            "item": [
                {
                    "name": "List Officers",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{jwt_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{BASE_URL}}/api/portal/police",
                            "host": [
                                "{{BASE_URL}}"
                            ],
                            "path": [
                                "api",
                                "portal",
                                "police"
                            ]
                        }
                    }
                }
            ]
        }
    ],
    "variable": [
        {
            "key": "BASE_URL",
            "value": "http://localhost:5000"
        },
        {
            "key": "jwt_token",
            "value": "YOUR_TOKEN_HERE"
        }
    ]
}